weights/onnx/
weights/engine/
weights/openvino/
weights/*.zip

# Keep models.json manifest
!weights/models.json

# Test videos (large files)
test/*.mp4
test/*.avi

# IDEs & System
.vscode/
.idea/
.DS_Store
Thumbs.db

# Docker
# Keep .dockerignore tracked

# Environment
.env
